// Determina se o input é do lightbox (foto) ou da página (álbum)
function vaSubmitComment(inputId) {
    const isLightbox = inputId === 'vaLbCommentInput';
    if (isLightbox) {
        vaSubmitPhotoComment(inputId);
    } else {
        vaSubmitAlbumComment(inputId);
