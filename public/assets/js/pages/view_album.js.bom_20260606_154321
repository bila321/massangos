let vaLbCommentsLoaded = false;

function vaOpenLightbox(idx) {
    vaCurrentIdx = idx;
    // Abre sem blur apenas se esta foto foi revelada no grid pelo utilizador
    vaLbBlurRevealed = (vaRevealedThumbIdx === idx);
    vaLoadPhoto(idx);
